[
  // v1 full = all 13 agents: Hermes + Hephaestus + Athena + Plutus + Themis + Nemesis + Iris + Asclepius + Argus + Prometheus + Mnemosyne + Calliope + Persephone
  // All models route through LiteLLM. Sandbox disabled for K8s v1.
  {
    id: "hermes",
    default: true,
    workspace: "/home/node/.openclaw/workspaces/hermes",
    model: "litellm/glm-5-turbo",
    sandbox: { mode: "off" },
    subagents: { allowAgents: ["hephaestus", "athena", "plutus", "themis", "nemesis", "iris", "asclepius", "argus", "prometheus", "mnemosyne", "calliope", "persephone"] },
    tools: {
      // profile: "full" + deny is required — "minimal" does not expose sessions_spawn reliably
      // even when sessions_spawn is in the explicit allow list. See openclaw/openclaw#47862.
      // MCP tools MUST be explicitly listed in allow[] — profile: "full" alone does not
      // guarantee MCP tool visibility. Without explicit allow, agents cannot see or call them.
      // "message" removed from deny to allow WhatsApp audio/text delivery via TTS pipeline.
      profile: "full",
      allow: ["mcp:google-calendar", "mcp:ticktick", "mcp:n8n", "mcp:sequential-thinking"],
      deny: ["write", "edit", "apply_patch", "exec", "process", "browser", "canvas", "web_search", "web_fetch", "cron", "gateway", "image"],
      loopDetection: { enabled: true },
    },
  },
  {
    id: "hephaestus",
    workspace: "/home/node/.openclaw/workspaces/hephaestus",
    model: "litellm/qwen3-coder-plus",
    sandbox: {
      mode: "all",
      scope: "agent",
      workspaceAccess: "rw",
      docker: {
        image: "git.ramoneees.com/ramoneees/hephaestus-dev:latest",
        network: "bridge",
        env: ["NODE_ENV=development"],
        binds: [
          "/home/ramoneees/repos:/repos:rw",
          "/home/ramoneees/.gitconfig:/etc/gitconfig:ro",
          "/home/ramoneees/.ssh:/home/node/.ssh:ro",
        ],
      },
    },
    tools: {
      profile: "coding",
      allow: ["group:fs", "group:runtime", "group:memory", "web_search", "web_fetch", "session_status", "message", "sessions_spawn"],
      deny: ["sessions_list", "sessions_history", "sessions_send", "browser", "canvas", "cron", "gateway"],
      elevated: { enabled: false },
      loopDetection: { enabled: true },
    },
  },
  {
    id: "athena",
    workspace: "/home/node/.openclaw/workspaces/athena",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["read", "group:memory", "web_search", "web_fetch", "browser", "session_status", "message", "mcp:web-search-prime", "mcp:web-reader", "mcp:zreader"],
      deny: ["write", "edit", "apply_patch", "exec", "process", "sessions_list", "sessions_history", "sessions_send", "sessions_spawn", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // PLUTUS: Finance agent. Cloud model (budget constraint) — hardened:
    // no web_fetch (prevents data exfiltration), no broad fs writes,
    // firefly-iii MCP for structured finance queries.
    id: "plutus",
    workspace: "/home/node/.openclaw/workspaces/plutus",
    model: "litellm/openrouter/minimax/minimax-m2.7",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["read", "write", "group:memory", "session_status", "message", "sessions_spawn", "mcp:sequential-thinking", "mcp:firefly-iii"],
      deny: ["edit", "apply_patch", "exec", "process", "browser", "web_search", "web_fetch", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    id: "themis",
    workspace: "/home/node/.openclaw/workspaces/themis",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["read", "group:memory", "web_search", "web_fetch", "session_status", "message", "mcp:sequential-thinking"],
      deny: ["write", "edit", "apply_patch", "exec", "process", "sessions_list", "sessions_history", "sessions_send", "sessions_spawn", "browser", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    id: "prometheus",
    workspace: "/home/node/.openclaw/workspaces/prometheus",
    model: "litellm/qwen3-coder-plus",
    sandbox: { mode: "off" },
    tools: {
      profile: "coding",
      allow: ["group:fs", "group:runtime", "group:memory", "web_search", "web_fetch", "session_status", "message", "sessions_spawn"],
      deny: ["sessions_list", "sessions_history", "sessions_send", "browser", "canvas", "cron", "gateway"],
      elevated: { enabled: false },
      loopDetection: { enabled: true },
    },
  },
  {
    id: "mnemosyne",
    workspace: "/home/node/.openclaw/workspaces/mnemosyne",
    model: "litellm/qwen3:8b",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["read", "group:memory", "memory_search", "memory_get", "memory_put", "session_status", "message"],
      deny: ["write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "sessions_spawn", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // NEMESIS: Critique, bias detection, and decision stress-testing agent.
    // Minimal profile + memory, sessions_spawn, message, sequential-thinking MCP.
    id: "nemesis",
    workspace: "/home/node/.openclaw/workspaces/nemesis",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["group:memory", "sessions_spawn", "session_status", "message", "mcp:sequential-thinking"],
      deny: ["read", "write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // CALLIOPE: Writing, knowledge capture, and content agent.
    // Minimal profile + read, message, sessions_spawn for research delegation.
    id: "calliope",
    workspace: "/home/node/.openclaw/workspaces/calliope",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["read", "group:memory", "sessions_spawn", "session_status", "message", "mcp:sequential-thinking"],
      deny: ["write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // IRIS: Communication and messaging agent.
    // Minimal profile + memory, sessions_spawn, message, sequential-thinking MCP.
    id: "iris",
    workspace: "/home/node/.openclaw/workspaces/iris",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["read", "group:memory", "sessions_spawn", "session_status", "message", "mcp:sequential-thinking"],
      deny: ["write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // ASCLEPIUS: Health, recovery, and wellness agent.
    // Minimal profile + memory, sessions_spawn, message, sequential-thinking MCP.
    id: "asclepius",
    workspace: "/home/node/.openclaw/workspaces/asclepius",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["group:memory", "sessions_spawn", "session_status", "message", "mcp:sequential-thinking"],
      deny: ["read", "write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // ARGUS: Monitoring, alerts, and watchlists agent.
    // Minimal profile + memory, sessions_spawn, message, sequential-thinking + kubernetes MCPs.
    id: "argus",
    workspace: "/home/node/.openclaw/workspaces/argus",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["group:memory", "sessions_spawn", "session_status", "message", "mcp:sequential-thinking", "mcp:kubernetes"],
      deny: ["read", "write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
  {
    // PERSEPHONE: Planning, organization, and GTD agent.
    // Minimal profile + memory_search, sessions_spawn, message, sequential-thinking MCP.
    id: "persephone",
    workspace: "/home/node/.openclaw/workspaces/persephone",
    model: "litellm/MiniMax-M2.5",
    sandbox: { mode: "off" },
    tools: {
      profile: "minimal",
      allow: ["group:memory", "sessions_spawn", "session_status", "message", "mcp:sequential-thinking"],
      deny: ["read", "write", "edit", "apply_patch", "exec", "process", "web_search", "web_fetch", "browser", "sessions_list", "sessions_history", "sessions_send", "canvas", "cron", "gateway"],
      loopDetection: { enabled: true },
    },
  },
]
