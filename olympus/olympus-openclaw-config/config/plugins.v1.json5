{
  // Functional v1 plugin set.
  // Keep this minimal so the system boots cleanly before custom OLYMPUS plugins exist.

  enabled: true,
  allow: [
    "memory-core",
    "qwen-portal-auth",
    "mattermost",
    "whatsapp",
  ],
  load: {
    paths: [
      "~/.openclaw/data/extensions",
    ],
  },
  entries: {
    "qwen-portal-auth": {
      enabled: true,
    },
    "mattermost": {
      enabled: true,
    },
    "whatsapp": {
      enabled: true,
    },
  },
  slots: {
    memory: "memory-core",
    contextEngine: "legacy",
  },
}
