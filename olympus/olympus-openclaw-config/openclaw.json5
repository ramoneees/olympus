{
  // OLYMPUS v1 root config for OpenClaw — K8s deployment.
  // Mounted at /home/ramoneees/.openclaw/openclaw.json via ConfigMap.

  agents: {
    defaults: { $include: "./config/agents.defaults.json5" },
    list: { $include: "./config/agents.list.v1-full.json5" },
  },

  bindings: { $include: "./config/bindings.v1.json5" },

  tools: { $include: "./config/tools.global.json5" },

  models: {
    mode: "merge",
    providers: { $include: "./config/models.providers.json5" },
  },

  plugins: { $include: "./config/plugins.v1.json5" },

  gateway: {
    port: 18789,
    mode: "local",
    bind: "lan",
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    trustedProxies: ["10.42.0.0/16", "10.43.0.0/16", "192.168.50.0/24"],
    controlUi: {
      allowedOrigins: ["https://openclaw.ramoneees.com"],
    },
  },

  hooks: {
    enabled: true,
    path: "/hooks",
    token: "${OPENCLAW_HOOKS_TOKEN}",
    defaultSessionKey: "hook:ingress",
    allowedAgentIds: ["hermes", "hephaestus", "athena", "plutus", "themis", "nemesis", "iris", "asclepius", "argus", "prometheus", "mnemosyne", "calliope", "persephone"],
    internal: {
      enabled: true,
      entries: {
        "boot-md": { enabled: true },
        "command-logger": { enabled: true },
        "session-memory": { enabled: true },
      },
    },
  },

  channels: {
    whatsapp: {
      dmPolicy: "allowlist",
      allowFrom: ["+351926565596"],
      selfChatMode: true,
      sendReadReceipts: true,
      ackReaction: {
        emoji: "👀",
        direct: true,
        group: "mentions",
      },
    },
    mattermost: {
      enabled: true,
      botToken: "${MATTERMOST_BOT_TOKEN}",
      baseUrl: "${MATTERMOST_URL}",
      allowPrivateNetwork: true,
      dmPolicy: "pairing",
      chatmode: "oncall",
      interactions: {
        callbackBaseUrl: "https://openclaw.ramoneees.com",
        allowedSourceIps: ["10.42.0.0/16", "10.43.0.0/16", "192.168.50.0/24"],
      },
    },
  },

  skills: {
    install: {
      preferBrew: true,
      nodeManager: "npm",
    },
  },

  web: {
    enabled: true,
    fetch: {
      allowPrivateNetwork: true,
    },
  },
  memory: { backend: "builtin" },
  commands: { native: "auto" },
  cron: {
    enabled: true,
    store: "~/.openclaw/cron/jobs.json",
    maxConcurrentRuns: 2,
    retry: {
      maxAttempts: 3,
      backoffMs: [60000, 120000, 300000],
      retryOn: ["rate_limit", "overloaded", "network", "server_error"],
    },
    sessionRetention: "48h",
  },

  // MCP servers — must be declared here for OpenClaw to expose them to agents.
  // mcporter.json handles the runtime transport; this section makes them visible in the agent tool list.
  mcp: {
    servers: {
      "google-calendar": {
        command: "npx",
        args: ["-y", "@cocal/google-calendar-mcp"],
        env: {
          GOOGLE_OAUTH_CREDENTIALS: "/home/ramoneees/.openclaw/credentials/google-calendar/gcp-oauth.keys.json",
          GOOGLE_CALENDAR_MCP_TOKEN_PATH: "/home/ramoneees/.openclaw/credentials/google-calendar/.tokens.json",
        },
      },
      ticktick: {
        description: "TickTick task management (official MCP)",
        url: "https://mcp.ticktick.com",
        transport: "streamable-http",
        auth: "oauth",
        tokenCacheDir: "/home/ramoneees/.openclaw/credentials/ticktick",
      },
      n8n: {
        transport: "streamable-http",
        baseUrl: "http://192.168.50.11:30567/mcp-server/http",
        headers: { Authorization: "Bearer ${N8N_MCP_TOKEN}" },
      },
      "sequential-thinking": {
        command: "npx",
        args: ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      },
      kubernetes: {
        command: "npx",
        args: ["-y", "kubernetes-mcp-server@latest", "--disable-destructive"],
      },
      filesystem: {
        command: "npx",
        args: ["-y", "@modelcontextprotocol/server-filesystem", "/home/ramoneees/.openclaw/workspaces"],
      },
      postgres: {
        command: "npx",
        args: ["-y", "@modelcontextprotocol/server-postgres", "${POSTGRES_URL}"],
      },
      "web-search-prime": {
        transport: "streamable-http",
        url: "https://api.z.ai/api/mcp/web_search_prime/mcp",
        headers: { Authorization: "Bearer ${Z_AI_API_KEY}" },
      },
      "web-reader": {
        transport: "streamable-http",
        url: "https://api.z.ai/api/mcp/web_reader/mcp",
        headers: { Authorization: "Bearer ${Z_AI_API_KEY}" },
      },
      zreader: {
        transport: "streamable-http",
        url: "https://api.z.ai/api/mcp/zread/mcp",
        headers: { Authorization: "Bearer ${Z_AI_API_KEY}" },
      },
      "firefly-iii": {
        command: "npx",
        args: ["-y", "@firefly-iii-mcp/local"],
        env: {
          FIREFLY_III_BASE_URL: "${FIREFLY_III_BASE_URL}",
          FIREFLY_III_PAT: "${FIREFLY_III_PAT}",
        },
      },
    },
  },
}
